            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Smith\",\n  \"image_url\": \"https://example.com/avatars/jane-new.png\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "https://your-api-id.execute-api.us-east-1.amazonaws.com/api/users/profile",
              "protocol": "https",
              "host": ["your-api-id", "execute-api", "us-east-1", "amazonaws", "com"],
              "path": ["api", "users", "profile"]
            },
            "description": "Update the display name and/or avatar URL for the authenticated user.\n\n**Auth:** Bearer token required.\n\n### Body fields\n| Field | Type | Required |\n|---|---|---|\n| `first_name` | string | yes |\n| `last_name` | string | yes |\n| `image_url` | string | yes |"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Smith\",\n  \"image_url\": \"https://example.com/avatars/jane-new.png\",\n  \"email\": \"jane.doe@example.com\",\n  \"role\": \"Customer\"\n}"
            }
          ]
        }
      ]
    },
