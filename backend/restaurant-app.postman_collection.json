    {
      "name": "Bookings",
      "description": "Table availability checks and reservation CRUD. Requires a Customer JWT for write operations.",
      "item": [
        {
          "name": "Get Available Tables",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/bookings/tables?location_id={{location_id}}&date=2026-05-28&guests_number=2&from_time=12:00",
              "host": ["{{base_url}}"],
              "path": ["bookings", "tables"],
              "query": [
                {
                  "key": "location_id",
                  "value": "{{location_id}}",
                  "description": "Required. UUID of the restaurant location"
                },
                {
                  "key": "date",
                  "value": "2026-05-28",
                  "description": "Required. YYYY-MM-DD format. Must not be in the past; max 30 days ahead"
                },
                {
                  "key": "guests_number",
                  "value": "2",
                  "description": "Required. Integer 1-10"
                },
                {
                  "key": "from_time",
                  "value": "12:00",
                  "description": "Optional. HH:MM – snaps to nearest valid slot start"
                }
              ]
            },
            "description": "Returns tables with available 90-minute slots that fit the requested party size, date, and optional start time."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"tables\": [\n    {\n      \"table_id\": \"tb000001-0000-0000-0000-000000000001\",\n      \"table_number\": 5,\n      \"capacity\": 4,\n      \"location_address\": \"123 Main Street, New York, NY\",\n      \"available_slots\": [\n        {\n          \"slot_id\": \"sl000001-0000-0000-0000-000000000001\",\n          \"start_time\": \"12:00\",\n          \"end_time\": \"13:30\"\n        },\n        {\n          \"slot_id\": \"sl000001-0000-0000-0000-000000000002\",\n          \"start_time\": \"14:00\",\n          \"end_time\": \"15:30\"\n        }\n      ]\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.reservationId) { pm.collectionVariables.set('reservation_id', json.reservationId); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/bookings/client",
              "host": ["{{base_url}}"],
              "path": ["bookings", "client"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"locationId\": \"{{location_id}}\",\n  \"tableNumber\": 5,\n  \"date\": \"2026-05-28\",\n  \"guestsNumber\": 2,\n  \"timeFrom\": \"12:00\",\n  \"timeTo\": \"13:30\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a new reservation. **Customer role required.** Slots are 90 minutes long. The test script saves `reservation_id` automatically.\n\n- `date`: YYYY-MM-DD, not in the past, max 30 days ahead\n- `timeFrom` / `timeTo`: HH:MM; `timeTo` must be after `timeFrom`\n- `guestsNumber`: 1-10"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"reservationId\": \"res00001-0000-0000-0000-000000000001\",\n  \"status\": \"RESERVED\",\n  \"locationId\": \"00000000-0000-0000-0000-000000000001\",\n  \"location_address\": \"123 Main Street, New York, NY\",\n  \"tableNumber\": 5,\n  \"date\": \"2026-05-28\",\n  \"timeFrom\": \"12:00\",\n  \"timeTo\": \"13:30\",\n  \"guestsNumber\": 2\n}"
            },
            {
              "name": "403 Forbidden (non-Customer role)",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Forbidden\"\n}"
            }
          ]
        },
        {
          "name": "List My Bookings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/bookings/client",
              "host": ["{{base_url}}"],
              "path": ["bookings", "client"]
            },
            "description": "Returns all reservations belonging to the authenticated user (Customer or Waiter). Includes `allowedActions` flags that indicate whether the reservation can still be edited or cancelled."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"reservations\": [\n    {\n      \"reservationId\": \"res00001-0000-0000-0000-000000000001\",\n      \"status\": \"RESERVED\",\n      \"customerId\": \"a1b2c3d4-0000-0000-0000-000000000001\",\n      \"waiterId\": null,\n      \"locationId\": \"00000000-0000-0000-0000-000000000001\",\n      \"location_address\": \"123 Main Street, New York, NY\",\n      \"tableNumber\": 5,\n      \"date\": \"2026-05-28\",\n      \"timeFrom\": \"12:00\",\n      \"timeTo\": \"13:30\",\n      \"guestsNumber\": 2,\n      \"allowedActions\": {\n        \"canEdit\": true,\n        \"canCancel\": true\n      },\n      \"cutoffReason\": null\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Get Booking by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/bookings/client/{{reservation_id}}",
              "host": ["{{base_url}}"],
              "path": ["bookings", "client", "{{reservation_id}}"]
            },
            "description": "Retrieve the full details of a single reservation by its UUID."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"reservationId\": \"res00001-0000-0000-0000-000000000001\",\n  \"status\": \"RESERVED\",\n  \"customerId\": \"a1b2c3d4-0000-0000-0000-000000000001\",\n  \"waiterId\": null,\n  \"locationId\": \"00000000-0000-0000-0000-000000000001\",\n  \"location_address\": \"123 Main Street, New York, NY\",\n  \"tableNumber\": 5,\n  \"date\": \"2026-05-28\",\n  \"timeFrom\": \"12:00\",\n  \"timeTo\": \"13:30\",\n  \"guestsNumber\": 2,\n  \"allowedActions\": {\n    \"canEdit\": true,\n    \"canCancel\": true\n  },\n  \"cutoffReason\": null\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Reservation not found\"\n}"
            }
          ]
        },
        {
          "name": "Update Booking",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/bookings/client/{{reservation_id}}",
              "host": ["{{base_url}}"],
              "path": ["bookings", "client", "{{reservation_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestsNumber\": 3,\n  \"status\": null\n}",
              "options": { "raw": { "language": "json" } }
            },
