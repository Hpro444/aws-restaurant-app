{
  "info": {
    "name": "Restaurant App API",
    "_postman_id": "restaurant-app-collection",
    "description": "Full API collection for the Restaurant App backend. Set the `base_url` variable to your API Gateway URL before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://your-api-id.execute-api.us-east-1.amazonaws.com/dev",
      "type": "string",
      "description": "API Gateway base URL (no trailing slash)"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT access token – populated automatically by the sign-in test script"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string",
      "description": "Refresh token – populated automatically by the sign-in test script"
    },
    {
      "key": "location_id",
      "value": "00000000-0000-0000-0000-000000000001",
      "type": "string",
      "description": "UUID of the location to use in location/booking requests"
    },
    {
      "key": "reservation_id",
      "value": "",
      "type": "string",
      "description": "UUID of a reservation – populated automatically by the create-booking test script"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints – sign-up, sign-in, token refresh, and logout.",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/sign-up",
              "host": ["{{base_url}}"],
              "path": ["auth", "sign-up"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"Password1!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Register a new user. Role is assigned automatically (Customer by default; Waiter if the email appears in the waiter-emails table).\n\n**Password rules:** 8-16 characters, at least one uppercase letter, one lowercase letter, one digit, and one special character."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"user_id\": \"a1b2c3d4-0000-0000-0000-000000000001\",\n  \"message\": \"User registered successfully\"\n}"
            }
          ]
        },
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token)  { pm.collectionVariables.set('access_token',  json.access_token);  }",
                  "if (json.refresh_token) { pm.collectionVariables.set('refresh_token', json.refresh_token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/sign-in",
              "host": ["{{base_url}}"],
              "path": ["auth", "sign-in"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"Password1!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Authenticate a user and receive an access token + refresh token.\n\n**After 5 failed attempts** the account is locked for 15 minutes.\n\nThe test script automatically stores `access_token` and `refresh_token` as collection variables."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"access_token\": \"eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refresh_token\": \"eyJjdHkiOiJKV1QiLCJlbmMiOiJBMjU2R0NNIiwiYWxnIjoiUlNBLU9BRVAifQ...\",\n  \"username\": \"jane.doe@example.com\",\n  \"role\": \"Customer\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Invalid credentials\"\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) { pm.collectionVariables.set('access_token', json.access_token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Exchange a refresh token for a new access token. The test script updates the `access_token` collection variable automatically."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"access_token\": \"eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Invalidate the refresh token to end the session."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Logged out successfully\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "description": "Authenticated user profile operations.",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            },
            "description": "Retrieve the profile of the currently authenticated user."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Doe\",\n  \"image_url\": \"https://example.com/avatars/jane.png\",\n  \"email\": \"jane.doe@example.com\",\n  \"role\": \"Customer\"\n}"
            }
          ]
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/users/profile",
              "host": ["{{base_url}}"],
              "path": ["users", "profile"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Smith\",\n  \"image_url\": \"https://example.com/avatars/jane-new.png\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Update the display name and/or avatar URL for the authenticated user."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Smith\",\n  \"image_url\": \"https://example.com/avatars/jane-new.png\",\n  \"email\": \"jane.doe@example.com\",\n  \"role\": \"Customer\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Locations",
      "description": "Public endpoints for restaurant locations, specialty dishes, and customer feedback.",
      "item": [
        {
          "name": "List All Locations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/locations",
              "host": ["{{base_url}}"],
              "path": ["locations"]
            },
            "description": "Returns all restaurant locations with capacity, occupancy, rating, and image."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": \"00000000-0000-0000-0000-000000000001\",\n    \"address\": \"123 Main Street, New York, NY\",\n    \"description\": \"Our flagship downtown location.\",\n    \"total_capacity\": \"80\",\n    \"average_occupancy\": \"65\",\n    \"image_url\": \"https://example.com/locations/main.jpg\",\n    \"rating\": \"4.5\"\n  }\n]"
            }
          ]
        },
        {
          "name": "List Location Select Options",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/locations/select-options",
              "host": ["{{base_url}}"],
              "path": ["locations", "select-options"]
            },
            "description": "Lightweight endpoint that returns only `location_id` + `location_address` pairs, suited for dropdown pickers."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"location_id\": \"00000000-0000-0000-0000-000000000001\",\n    \"location_address\": \"123 Main Street, New York, NY\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Get Location by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/locations/{{location_id}}",
              "host": ["{{base_url}}"],
              "path": ["locations", "{{location_id}}"]
            },
            "description": "Retrieve full details for a single location by its UUID."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"00000000-0000-0000-0000-000000000001\",\n  \"address\": \"123 Main Street, New York, NY\",\n  \"description\": \"Our flagship downtown location.\",\n  \"total_capacity\": \"80\",\n  \"average_occupancy\": \"65\",\n  \"image_url\": \"https://example.com/locations/main.jpg\",\n  \"rating\": \"4.5\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Location not found\"\n}"
            }
          ]
        },
        {
          "name": "Get Location Speciality Dishes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/locations/{{location_id}}/speciality-dishes",
              "host": ["{{base_url}}"],
              "path": ["locations", "{{location_id}}", "speciality-dishes"]
            },
            "description": "Returns the specialty dishes offered at a specific location."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"name\": \"Truffle Risotto\",\n    \"image_url\": \"https://example.com/dishes/risotto.jpg\",\n    \"price\": 24.99,\n    \"weight_gram\": 350\n  }\n]"
            }
          ]
        },
        {
          "name": "Get Location Feedbacks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/locations/{{location_id}}/feedbacks?type=cuisine&sort=date,desc&page=0&size=20",
              "host": ["{{base_url}}"],
              "path": ["locations", "{{location_id}}", "feedbacks"],
              "query": [
                {
                  "key": "type",
                  "value": "cuisine",
                  "description": "Required. 'cuisine' or 'service'"
                },
                {
                  "key": "sort",
                  "value": "date,desc",
                  "description": "Optional. '{field},{direction}' – field: 'date' or 'rate'; direction: 'asc' or 'desc'. Default: 'date,desc'"
                },
                {
                  "key": "page",
                  "value": "0",
                  "description": "Optional. 0-indexed page number. Default: 0"
                },
                {
                  "key": "size",
                  "value": "20",
                  "description": "Optional. Items per page (1-100). Default: 20"
                }
              ]
            },
            "description": "Paginated, sortable feedback for a location. `type` is required (`cuisine` or `service`)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"totalPages\": 3,\n  \"totalElements\": 55,\n  \"size\": 20,\n  \"content\": [\n    {\n      \"id\": \"fb000001-0000-0000-0000-000000000001\",\n      \"customer_id\": \"a1b2c3d4-0000-0000-0000-000000000001\",\n      \"feedback\": \"Amazing food and great atmosphere!\",\n      \"rate\": 5,\n      \"date\": \"2026-05-15T18:30:00Z\"\n    }\n  ],\n  \"number\": 0,\n  \"sort\": [\"date,desc\"],\n  \"first\": true,\n  \"last\": false,\n  \"numberOfElements\": 20,\n  \"pageable\": {\n    \"offset\": 0,\n    \"sort\": [\"date,desc\"],\n    \"paged\": true,\n    \"pageSize\": 20,\n    \"pageNumber\": 0,\n    \"unpaged\": false\n  },\n  \"empty\": false\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Dishes",
      "description": "Dish catalogue endpoints.",
      "item": [
        {
          "name": "Get Popular Dishes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/dishes/popular",
              "host": ["{{base_url}}"],
              "path": ["dishes", "popular"]
            },
            "description": "Returns the globally most-popular dishes across all locations."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"name\": \"Margherita Pizza\",\n    \"image_url\": \"https://example.com/dishes/margherita.jpg\",\n    \"price\": 14.99,\n    \"weight_gram\": 500\n  },\n  {\n    \"name\": \"Caesar Salad\",\n    \"image_url\": \"https://example.com/dishes/caesar.jpg\",\n    \"price\": 11.50,\n    \"weight_gram\": 300\n  }\n]"
            }
