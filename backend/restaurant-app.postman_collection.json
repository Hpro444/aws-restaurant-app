    {
      "name": "Bookings",
      "description": "Table availability checks and reservation CRUD. Requires a Customer JWT for write operations.",
      "item": [
        {
          "name": "Get Available Tables",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = new Date();",
                  "const yyyy = String(now.getUTCFullYear());",
                  "const mm = String(now.getUTCMonth() + 1).padStart(2, '0');",
                  "const dd = String(now.getUTCDate()).padStart(2, '0');",
                  "const bookingDate = `${yyyy}-${mm}-${dd}`;",
                  "const fromTime = now.toISOString().slice(0, 19) + 'Z';",
                  "pm.request.url.query.upsert({ key: 'date', value: bookingDate });",
                  "pm.request.url.query.upsert({ key: 'from_time', value: fromTime });",
                  "pm.environment.set('booking_date', bookingDate);",
                  "pm.environment.set('from_time', fromTime);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://your-api-id.execute-api.us-east-1.amazonaws.com/api/bookings/tables?location_id=00000000-0000-0000-0000-000000000001&date={{booking_date}}&guests_number=2&from_time={{from_time}}",
              "protocol": "https",
              "host": ["your-api-id", "execute-api", "us-east-1", "amazonaws", "com"],
              "path": ["api", "bookings", "tables"],
              "query": [
                {
                  "key": "location_id",
                  "value": "00000000-0000-0000-0000-000000000001",
                  "description": "Required. UUID of the restaurant location."
                },
                {
                  "key": "date",
                  "value": "{{booking_date}}",
                  "description": "Required. YYYY-MM-DD. Must not be in the past; max 30 days ahead."
                },
                {
                  "key": "guests_number",
                  "value": "2",
                  "description": "Required. Integer 1-10."
                },
                {
                  "key": "from_time",
                  "value": "{{from_time}}",
                  "description": "Optional. UTC ISO datetime (e.g. 2026-05-27T13:45:00Z)."
                }
              ]
            },
            "description": "Returns tables with available 90-minute slots that fit the requested party size, date, and optional start time.\n\n`date` and `from_time` are auto-filled on each send by a pre-request script (UTC), so you don't need to set them manually in Postman."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"tables\": [\n    {\n      \"table_id\": \"tb000001-0000-0000-0000-000000000001\",\n      \"table_number\": 5,\n      \"capacity\": 4,\n      \"location_address\": \"48 Rustaveli Avenue, Tbilisi\",\n      \"available_slots\": [\n        {\n          \"slot_id\": \"sl000001-0000-0000-0000-000000000001\",\n          \"start_time\": \"2026-05-28T12:00:00Z\",\n          \"end_time\": \"2026-05-28T13:30:00Z\"\n        },\n        {\n          \"slot_id\": \"sl000001-0000-0000-0000-000000000002\",\n          \"start_time\": \"2026-05-28T14:00:00Z\",\n          \"end_time\": \"2026-05-28T15:30:00Z\"\n        }\n      ]\n    }\n  ]\n}"
            },
            {
              "name": "422 Unprocessable Entity",
              "status": "Unprocessable Entity",
              "code": 422,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"errors\": [\n    { \"field\": \"guests_number\", \"message\": \"Must be a valid integer\" }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('booking_date')) {",
                  "  const now = new Date();",
                  "  const yyyy = String(now.getUTCFullYear());",
                  "  const mm = String(now.getUTCMonth() + 1).padStart(2, '0');",
                  "  const dd = String(now.getUTCDate()).padStart(2, '0');",
                  "  pm.environment.set('booking_date', `${yyyy}-${mm}-${dd}`);",
                  "}",
                  "if (!pm.environment.get('guests')) pm.environment.set('guests', '2');",
                  "if (!pm.environment.get('location_id')) pm.environment.set('location_id', '00000000-0000-0000-0000-000000000001');",
                  "if (!pm.environment.get('table_number')) pm.environment.set('table_number', '1');",
                  "const now = new Date();",
                  "if (!pm.environment.get('from_time') || !pm.environment.get('to_time')) {",
                  "  const end = new Date(now.getTime() + 90 * 60 * 1000);",
                  "  if (!pm.environment.get('from_time')) pm.environment.set('from_time', now.toISOString().slice(0, 19) + 'Z');",
                  "  if (!pm.environment.get('to_time')) pm.environment.set('to_time', end.toISOString().slice(0, 19) + 'Z');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer YOUR_ACCESS_TOKEN" },
              { "key": "Content-Type", "value": "application/json" }
