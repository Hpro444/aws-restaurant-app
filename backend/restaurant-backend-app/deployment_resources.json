  "${login_attempts_table}": {
    "resource_type": "dynamodb_table",
    "hash_key_name": "email",
    "hash_key_type": "S",
    "read_capacity": 1,
    "write_capacity": 1,
    "ttl_attribute_name": "lockout_until",
    "global_indexes": [],
    "autoscaling": [],
    "tags": {}
  },
  "${user_pool_name}": {
    "resource_type": "cognito_idp",
    "password_policy": {
      "minimum_length": 8,
      "require_uppercase": true,
      "require_symbols": true,
      "require_lowercase": true,
      "require_numbers": true
    },
    "auto_verified_attributes": [
      "email"
    ],
    "sms_configuration": {},
    "username_attributes": [],
    "custom_attributes": [
      {
        "name": "first_name",
        "type": "String",
        "mutable": true,
        "required": false
      },
      {
        "name": "last_name",
        "type": "String",
        "mutable": true,
        "required": false
      }
    ],
    "client": {
      "client_name": "restaurant-app-client",
      "generate_secret": false,
      "explicit_auth_flows": [
        "ALLOW_USER_PASSWORD_AUTH",
        "ALLOW_REFRESH_TOKEN_AUTH"
      ]
    },
    "tags": {}
  },
  "${waiters_table}": {
    "resource_type": "dynamodb_table",
    "hash_key_name": "id",
