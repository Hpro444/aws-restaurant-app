{
  "version": "1.0",
  "name": "data_capture_lambda",
  "func_name": "handler.lambda_handler",
  "resource_type": "lambda",
  "iam_role_name": "data_capture_lambda-role",
  "runtime": "python3.13",
  "memory": 128,
  "timeout": 100,
  "lambda_path": "lambdas\\data_capture_lambda",
  "dependencies": [],
  "event_sources": [
    {
      "resource_type": "sqs_trigger",
      "target_queue": "event_queue",
      "batch_size": 1,
      "enabled": true
    }
  ],
  "env_variables": {
    "WAITER_REPORT_TABLE": "${waiter_report_table}",
    "LOCATION_REPORT_TABLE": "${location_report_table}",
    "WAITERS_TABLE": "${waiters_table}",
    "LOCATIONS_TABLE": "${locations_table}",
    "RESERVATIONS_TABLE": "${reservations_table}",
    "SLOTS_TABLE": "${slots_table}",
    "FEEDBACK_SERVICE_TABLE": "${feedback_service_table}",
    "FEEDBACK_CUISINE_TABLE": "${feedback_cuisine_table}",
    "ORDERS_TABLE": "${orders_table}",
    "DISHES_TABLE": "${dishes_table}",
    "EVENT_QUEUE_URL": "${event_queue_url}"
  },
  "publish_version": true,
  "alias": "${lambdas_alias_data_capture_lambda}",
  "url_config": {},
  "ephemeral_storage": 512,
  "logs_expiration": "${logs_expiration}",
  "tags": {}
}
