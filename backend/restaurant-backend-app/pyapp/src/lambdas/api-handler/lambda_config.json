{
  "version": "1.0",
  "name": "api-handler",
  "func_name": "handler.lambda_handler",
  "resource_type": "lambda",
  "iam_role_name": "api-handler-role",
  "runtime": "python3.13",
  "memory": 128,
  "timeout": 100,
  "lambda_path": "lambdas\\api-handler",
  "dependencies": [],
  "event_sources": [],
  "env_variables": {
    "USER_POOL_NAME": "${user_pool_name}",
    "COGNITO_MAX_RESULTS": "${cognito_max_results}",
    "LOGIN_ATTEMPTS_TABLE": "${login_attempts_table}",
    "WAITERS_TABLE": "${waiters_table}",
    "CUSTOMERS_TABLE": "${customers_table}",
    "LOCATIONS_TABLE": "${locations_table}",
    "TABLES_TABLE": "${tables_table}",
    "DISHES_TABLE": "${dishes_table}",
    "SHIFTS_TABLE": "${shifts_table}",
    "SLOTS_TABLE": "${slots_table}",
    "RESERVATIONS_TABLE": "${reservations_table}",
    "FEEDBACK_CUISINE_TABLE": "${feedback_cuisine_table}",
    "FEEDBACK_SERVICE_TABLE": "${feedback_service_table}",
    "WAITER_EMAILS_TABLE": "${waiter_emails_table}",
    "ADMINS_TABLE": "${admins_table}",
    "ADMIN_EMAILS_TABLE": "${admin_emails_table}",
    "ORDERS_TABLE": "${orders_table}",
    "EVENT_QUEUE_URL": "${event_queue_url}"
  },
  "publish_version": true,
  "alias": "${lambdas_alias_name}",
  "url_config": {},
  "ephemeral_storage": 512,
  "logs_expiration": "${logs_expiration}",
  "tags": {}
}
